{
  "[latex]": {
    "editor.defaultFormatter": "mathematic.vscode-latex",
    "editor.formatOnSave": true
  },
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.recipe.default": "first",
  "latex-workshop.latex.tools": [
    {
      "name": "miktex-pdflatex",
      "command": "C:/Users/Admin/AppData/Local/Programs/MiKTeX/miktex/bin/x64/miktex-pdflatex.exe",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-output-directory=%DIR%",
        "%DOC%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "miktex-pdflatex x2",
      "tools": [
        "miktex-pdflatex",
        "miktex-pdflatex"
      ]
    }
  ],
  "latex-workshop.kpsewhich.path": "C:/Users/Admin/AppData/Local/Programs/MiKTeX/miktex/bin/x64/miktex-kpsewhich.exe",
  "workbench.editorAssociations": {
    "*.pdf": "latex-workshop-pdf-hook"
  },
  "latex.linter.enabled": false,
  "latex.formatter.columnLimit": 100,
  "latex.formatter.timeout": 10000,
  "latex.formatter.path": "tools/latexindent.cmd",
  "latex.formatter.config": ".latexindent.yaml",
  "explorer.sortOrder": "type",
  "files.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/.venv": true,
    "**/.vercel": true,
    "**/Report/build": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/.venv": true,
    "**/.vercel": true,
    "**/Report/build": true
  }
}
