      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$pdflatex = 'C:\\Users\\Admin\\AppData\\Local\\Programs\\MiKTeX\\miktex\\bin\\x64\\miktex-pdflatex.exe'; & $pdflatex -interaction=nonstopmode -halt-on-error report.tex; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; & $pdflatex -interaction=nonstopmode -halt-on-error report.tex"
