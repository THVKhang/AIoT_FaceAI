    {
      "label": "LaTeX: Clean aux files",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$files = @('report.aux','report.log','report.out','report.toc','report.fls','report.fdb_latexmk'); foreach ($f in $files) { if (Test-Path $f) { Remove-Item $f -Force } }"
